# Required unless launch-ado-mcp.sh can infer them from your Azure DevOps git remote
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization
AZURE_DEVOPS_PROJECT=Your Project

# Optional override for repository name
# AZURE_DEVOPS_REPOSITORY=your-repository

# Optional defaults
AZURE_DEVOPS_IS_ON_PREMISES=false
AZURE_DEVOPS_AUTH_TYPE=entra
